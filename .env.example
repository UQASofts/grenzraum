# Google Maps JavaScript API key (required for the interactive map).
# Enable "Maps JavaScript API" in Google Cloud Console.
# Use any one of the variable names below:
VITE_GOOGLE_MAPS_API_KEY="YOUR_GOOGLE_MAPS_API_KEY"
# GOOGLE_API_KEY="YOUR_GOOGLE_MAPS_API_KEY"
# GOOGLE_MAPS_PLATFORM_KEY="YOUR_GOOGLE_MAPS_API_KEY"

# Optional: custom Map ID from Google Cloud Console (for styled maps / advanced markers).
# Leave unset to use Google's demo map ID during development.
# VITE_GOOGLE_MAP_ID="YOUR_MAP_ID"

# GEMINI_API_KEY: Required for Gemini AI API calls.
# AI Studio automatically injects this at runtime from user secrets.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# APP_URL: The URL where this applet is hosted.
APP_URL="MY_APP_URL"
